---
import Base from '../layouts/Base.astro';
import LogoRow from '../components/LogoRow.astro';
import Figure from '../components/Figure.astro';
import StatBand from '../components/StatBand.astro';
import { SITE } from '../config';
import heroPhoto from '../assets/photos/home-hero-northwestern-garage.jpg';
---

<Base title={SITE.metaTitle} description={SITE.metaDescription}>
  <section class="section">
    <div class="container-wide">
      <div class="figure-split figure-split--hero">
        <div>
          <p class="eyebrow">Operating Executive &middot; Chicago</p>
          <h1 style="margin-top: 0.9rem;">Every Visionary needs an Integrator.</h1>
          <p style="margin-top: 1.5rem; font-size: 1.1rem;">
            I&rsquo;m Tom Vranas &mdash; second-seat executive and corporate fixer for founders,
            CEOs, and PE-backed companies in transition. COO, Chief of Staff, EOS Integrator: the
            person you hand the problem nobody&rsquo;s mapped. Twenty-five years, eight
            transactions, every seat in the building. I learn fast, fix what&rsquo;s broken, build
            the system that keeps it fixed &mdash; and work myself out of the job.
          </p>
          <p style="margin-top: 2rem;">
            <a class="btn" href="/contact" title="No deck required.">Start a conversation</a>
          </p>
        </div>
        <Figure
          src={heroPhoto}
          alt="Tom Vranas speaking at Northwestern's The Garage"
          caption="Speaking at Northwestern&rsquo;s The Garage."
          eager
        />
      </div>
    </div>
  </section>

  <section class="section" aria-label="Track record at a glance">
    <div class="container-wide">
      <StatBand
        stats={[
          { value: '25', label: 'Years operating' },
          { value: '8', label: 'Transactions' },
          { value: '11', label: 'Seats held' },
        ]}
      />
    </div>
  </section>

  <section class="section section--ink" aria-label="Selected transactions">
    <div class="container-wide">
      <div class="tombstones">
        <article class="tombstone">
          <span class="tombstone__index" aria-hidden="true">01</span>
          <p class="tombstone__name">ZENTRO INTERNET</p>
          <hr class="tombstone__rule" />
          <p class="tombstone__outcome">Recapitalized by Greystar&nbsp;Infrastructure</p>
          <p class="tombstone__year">2026</p>
        </article>
        <article class="tombstone">
          <span class="tombstone__index" aria-hidden="true">02</span>
          <p class="tombstone__name">GIGAMONSTER</p>
          <hr class="tombstone__rule" />
          <p class="tombstone__outcome">Acquired by Zentro&nbsp;Internet</p>
          <p class="tombstone__year">2023</p>
        </article>
        <article class="tombstone">
          <span class="tombstone__index" aria-hidden="true">03</span>
          <p class="tombstone__name">SNIP INTERNET</p>
          <hr class="tombstone__rule" />
          <p class="tombstone__outcome">Acquired by Zentro&nbsp;Internet</p>
          <p class="tombstone__year">2023</p>
        </article>
        <article class="tombstone">
          <span class="tombstone__index" aria-hidden="true">04</span>
          <p class="tombstone__name">SILVERIP</p>
          <hr class="tombstone__rule" />
          <p class="tombstone__outcome">Acquired by Zentro&nbsp;Internet</p>
          <p class="tombstone__year">2022</p>
        </article>
        <article class="tombstone">
          <span class="tombstone__index" aria-hidden="true">05</span>
          <p class="tombstone__name">EVERYWHERE WIRELESS</p>
          <hr class="tombstone__rule" />
          <p class="tombstone__outcome">Acquired by MC&nbsp;Partners</p>
          <p class="tombstone__year">2021</p>
        </article>
        <article class="tombstone">
          <span class="tombstone__index" aria-hidden="true">06</span>
          <p class="tombstone__name">SUPES ACADEMY</p>
          <hr class="tombstone__rule" />
          <p class="tombstone__outcome">Acquired by Atlantic Research&nbsp;Partners</p>
          <p class="tombstone__year">2015</p>
        </article>
        <article class="tombstone">
          <span class="tombstone__index" aria-hidden="true">07</span>
          <p class="tombstone__name">PROACT SEARCH</p>
          <hr class="tombstone__rule" />
          <p class="tombstone__outcome">Acquired by Atlantic Research&nbsp;Partners</p>
          <p class="tombstone__year">2015</p>
        </article>
        <article class="tombstone">
          <span class="tombstone__index" aria-hidden="true">08</span>
          <p class="tombstone__name">SOLTYRA</p>
          <hr class="tombstone__rule" />
          <p class="tombstone__outcome">Acqui-hired by The Princeton&nbsp;Review</p>
          <p class="tombstone__year">2008</p>
        </article>
      </div>
      <p class="tombstones__caption">
        Eight transactions, both sides of the table &mdash; as owner, operator, or integration
        lead.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>What I actually do</h2>
      <p style="margin-top: 1.2rem;">
        Strong-vision leaders are usually terrible at running the machine &mdash; and they
        shouldn&rsquo;t have to be. That&rsquo;s the seat I take, and I&rsquo;ll say plainly what
        most operators won&rsquo;t: I&rsquo;m not your forever manager. I&rsquo;m the one you send
        into the problem nobody&rsquo;s mapped &mdash; the post-close mess, the broken function,
        the company that grew faster than its systems. Half the time I haven&rsquo;t seen the
        exact problem before. It&rsquo;s never mattered.
      </p>
      <p class="lede-closer" style="margin-top: 1.2rem;">Fix, grow, systematize, exit. That&rsquo;s the job.</p>

      <div class="feature-grid" style="margin-top: 2.5rem;">
        <div class="feature-card">
          <span class="feature-card__index" aria-hidden="true">01</span>
          <h3>Operating rhythm</h3>
          <p>
            EOS Integrator in practice: scorecards, L10s, accountability charts. Founder intuition
            replaced with a company that runs on purpose.
          </p>
        </div>
        <div class="feature-card">
          <span class="feature-card__index" aria-hidden="true">02</span>
          <h3>Functional range</h3>
          <p>
            A call center, national marketing, the people function, innovation teams &mdash; every
            seat held as the accountable owner, not an advisor.
          </p>
        </div>
        <div class="feature-card">
          <span class="feature-card__index" aria-hidden="true">03</span>
          <h3>Deals</h3>
          <p>
            Eight transactions as owner, operator, or integration lead. I know what diligence looks
            for because I&rsquo;ve sat on both sides of it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-wide">
      <p class="eyebrow">Companies and institutions I&rsquo;ve worked with</p>
      <LogoRow />
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Have a company that&rsquo;s outgrown how it runs?</h2>
      <a class="btn" href="/contact" title="No deck required.">Start a conversation</a>
    </div>
  </section>
</Base>
