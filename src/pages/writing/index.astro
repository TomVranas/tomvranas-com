---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Ph from '../../components/Ph.astro';
import Figure from '../../components/Figure.astro';
import speakingPhoto from '../../assets/photos/writing-speaking-panel.webp';
import { SITE } from '../../config';

const schedulingIsPlaceholder = SITE.schedulingUrl.startsWith('{{');

const all = (await getCollection('writing')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// "Selected" strip: featured essays only, newest first, capped at five.
const featured = all
  .filter((p) => p.data.featured && (p.data.tags ?? []).includes('essay'))
  .slice(0, 5);

// The essay index shows ONLY essay-tagged posts (newest first). Bookshelf,
// notes, and hidden posts stay published + in the sitemap but are not listed.
const essays = all.filter((p) => (p.data.tags ?? []).includes('essay'));

const clean = (s: string) => s.replace(/&nbsp;| /g, ' ').trim();
const oneLine = (s: string | undefined) => {
  const c = clean(s ?? '');
  return c.length > 120 ? c.slice(0, 120).replace(/\s+\S*$/, '') + '…' : c;
};
---

<Base
  title="Writing — Field notes from the operating side | Tom Vranas"
  description="Weekly writing on integration, operating rigor, and what actually happens inside PE-backed companies after the press release."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Writing</p>
      <h1 style="margin-top: 0.9rem;">Field notes from the operating side.</h1>

      <p style="margin-top: 1.5rem;">
        I write weekly about integration, operating rigor, and what actually happens inside
        PE-backed companies after the press release. The polished versions live on
        <a href={SITE.medium} target="_blank" rel="noopener">Medium</a> and
        <a href={SITE.linkedin} target="_blank" rel="noopener">LinkedIn</a>; this page collects
        them.
      </p>
    </div>
  </section>

  {
    featured.length > 0 && (
      <section class="section">
        <div class="container">
          <p class="eyebrow">Selected</p>
          <div class="featured-grid" style="margin-top: 1.5rem;">
            {featured.map((post) => (
              <a class="featured-card" href={`/writing/${post.id}`}>
                <h2 class="featured-card__title">{clean(post.data.title)}</h2>
                {post.data.excerpt && (
                  <p class="featured-card__excerpt">{clean(post.data.excerpt)}</p>
                )}
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="quote-band">
    <div class="container">
      <blockquote class="quote-band__q">Fix, grow, systematize, exit.</blockquote>
      <p class="quote-band__attr">&mdash; Field Notes</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ol class="essays">
        {
          essays.map((post, i) => (
            <li class="essay" style={`--i: ${i}`}>
              <a class="essay__link" href={`/writing/${post.id}`}>
                <span class="essay__cat">{post.data.category ?? ''}</span>
                <span class="essay__main">
                  <span class="essay__title">{clean(post.data.title)}</span>
                  <span class="essay__excerpt">{oneLine(post.data.excerpt)}</span>
                </span>
              </a>
            </li>
          ))
        }
      </ol>

      <p class="reading-now-link">
        Reading now &mdash;
        <a href={SITE.goodreads} target="_blank" rel="noopener">see the shelf on Goodreads &rarr;</a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-wide">
      <div class="figure-split">
        <div>
          <h2>Speaking</h2>
          <p style="margin-top: 1.2rem;">
            I speak to leadership teams, PE portfolio gatherings, and industry groups on the themes
            I write about.
          </p>
          <ul class="topic-list">
            <li>PE Doesn&rsquo;t Fail at Close &mdash; why the value gets won or lost in the eighteen months after.</li>
            <li>Installing an Operating System Your Leadership Team Actually Keeps.</li>
            <li>The Corporate Fixer &mdash; why your hardest problems don&rsquo;t need a specialist.</li>
          </ul>
          <p style="margin-top: 1.75rem;">
            For availability:
            <a
              class="btn"
              href={SITE.schedulingUrl}
              target="_blank"
              rel="noopener"
              style="margin-left: 0.5rem;"
            >
              Book a conversation
            </a>
            {schedulingIsPlaceholder && <Ph>[Set SCHEDULING_URL in src/config.ts]</Ph>}
          </p>
        </div>
        <Figure src={speakingPhoto} alt="Tom Vranas speaking on a panel" caption="On a panel." />
      </div>
    </div>
  </section>
</Base>
