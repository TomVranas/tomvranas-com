---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Ph from '../../components/Ph.astro';
import Figure from '../../components/Figure.astro';
import speakingPhoto from '../../assets/photos/writing-speaking-panel.webp';
import { SITE } from '../../config';

const schedulingIsPlaceholder = SITE.schedulingUrl.startsWith('{{');

const all = (await getCollection('writing')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// "Selected" strip: up to six posts Tom flags featured: true.
const featured = all.filter((p) => p.data.featured).slice(0, 6);

// Canonical tag set for the filter. Posts carry explicit `tags` in frontmatter
// once Tom refines; until then we best-guess one from the title/excerpt so the
// filter is usable on day one.
const TAGS = ['operating', 'leadership', 'integration', 'culture', 'personal'] as const;

function tagsFor(post: (typeof all)[number]): string[] {
  if (post.data.tags?.length) return post.data.tags;
  const t = `${post.data.title} ${post.data.excerpt ?? ''}`.toLowerCase();
  const out = new Set<string>();
  if (/integrat|acquisi|merger|m&a|post-close|due diligence|deal\b|pe\b|private equity/.test(t))
    out.add('integration');
  if (/operat|system|process|\beos\b|scorecard|rhythm|execution|productiv|workflow|efficien/.test(t))
    out.add('operating');
  if (/leader|manage|\bboss\b|\bteam\b|influence|mentor|delegat|decision/.test(t))
    out.add('leadership');
  if (/culture|happ|wellbeing|well-being|mindful|empath|burnout|values|purpose|balance|human/.test(t))
    out.add('culture');
  if (/bookshelf|book\b|reading|review|memoir|\blife\b|magician|porsche|personal|journey/.test(t))
    out.add('personal');
  if (out.size === 0) out.add('operating');
  return [...out];
}

const clean = (s: string) => s.replace(/&nbsp;| /g, ' ').trim();
const fmtCard = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
const fmtLedger = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---

<Base
  title="Writing — Field notes from the operating side | Tom Vranas"
  description="Weekly writing on integration, operating rigor, and what actually happens inside PE-backed companies after the press release."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Writing</p>
      <h1 style="margin-top: 0.9rem;">Field notes from the operating side.</h1>

      <p style="margin-top: 1.5rem;">
        I write weekly about integration, operating rigor, and what actually happens inside
        PE-backed companies after the press release. The polished versions live on
        <a href={SITE.medium} target="_blank" rel="noopener">Medium</a> and
        <a href={SITE.linkedin} target="_blank" rel="noopener">LinkedIn</a>; this page collects
        them.
      </p>
    </div>
  </section>

  {
    featured.length > 0 && (
      <section class="section">
        <div class="container">
          <p class="eyebrow">Selected</p>
          <div class="featured-grid" style="margin-top: 1.5rem;">
            {featured.map((post) => (
              <a class="featured-card" href={`/writing/${post.id}`}>
                <time class="featured-card__date" datetime={post.data.date.toISOString()}>
                  {fmtCard(post.data.date)}
                </time>
                <h2 class="featured-card__title">{post.data.title}</h2>
                {post.data.excerpt && (
                  <p class="featured-card__excerpt">{clean(post.data.excerpt)}</p>
                )}
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="section">
    <div class="container">
      <div class="tag-filter" role="group" aria-label="Filter writing by tag">
        <button class="pill" type="button" data-tag="all" aria-pressed="true">All</button>
        {
          TAGS.map((tag) => (
            <button class="pill" type="button" data-tag={tag} aria-pressed="false">
              {tag}
            </button>
          ))
        }
      </div>

      <ul class="archive" style="margin-top: 1.75rem;">
        {
          all.map((post) => (
            <li class="archive__row" data-tags={tagsFor(post).join(' ')}>
              <time class="archive__date" datetime={post.data.date.toISOString()}>
                {fmtLedger(post.data.date)}
              </time>
              <a class="archive__title" href={`/writing/${post.id}`}>
                {clean(post.data.title)}
              </a>
            </li>
          ))
        }
      </ul>

      <p class="archive__empty" hidden>No posts with that tag yet.</p>

      <div class="archive__more">
        <button class="btn btn--ghost" type="button" id="load-more">Load more</button>
      </div>

      <aside class="reading-now">
        <span class="eyebrow">Reading now</span>
        <p>
          The current shelf &mdash; what I&rsquo;m reading and what just came off it &mdash; lives on
          <a href={SITE.goodreads} target="_blank" rel="noopener">Goodreads</a>.
        </p>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container-wide">
      <div class="figure-split">
        <div>
          <h2>Speaking</h2>
          <p style="margin-top: 1.2rem;">
            I speak to leadership teams, PE portfolio gatherings, and industry groups on the same
            themes I write about. Recent and recurring topics:
          </p>
          <ul class="topic-list">
            <li><Ph>[Topic 1 &mdash; e.g., Why PE doesn&rsquo;t fail at close]</Ph></li>
            <li><Ph>[Topic 2 &mdash; e.g., Installing an operating system a leadership team actually keeps]</Ph></li>
            <li><Ph>[Topic 3 &mdash; e.g., The case for the generalist operator]</Ph></li>
          </ul>
          <p style="margin-top: 1.75rem;">
            For availability:
            <a
              class="btn"
              href={SITE.schedulingUrl}
              target="_blank"
              rel="noopener"
              style="margin-left: 0.5rem;"
            >
              Book a conversation
            </a>
            {schedulingIsPlaceholder && <Ph>[Set SCHEDULING_URL in src/config.ts]</Ph>}
          </p>
        </div>
        <Figure src={speakingPhoto} alt="Tom Vranas speaking on a panel" caption="On a panel." />
      </div>
    </div>
  </section>
</Base>

<script>
  // /writing archive: tag filter + load-more pagination. No-JS users see the
  // full list. Keeps the page fast as the archive grows past 25 rows.
  const PAGE = 25;
  const archive = document.querySelector<HTMLElement>('.archive');
  const pills = Array.from(document.querySelectorAll<HTMLButtonElement>('.tag-filter .pill'));
  const moreBtn = document.querySelector<HTMLButtonElement>('#load-more');
  const empty = document.querySelector<HTMLElement>('.archive__empty');

  if (archive && moreBtn && empty) {
    const rows = Array.from(archive.querySelectorAll<HTMLElement>('.archive__row'));
    let activeTag = 'all';
    let shown = PAGE;

    const matches = (row: HTMLElement) =>
      activeTag === 'all' || (row.dataset.tags ?? '').split(' ').includes(activeTag);

    const render = () => {
      let visible = 0;
      rows.forEach((row) => {
        if (matches(row) && visible < shown) {
          row.hidden = false;
          visible++;
        } else {
          row.hidden = true;
        }
      });
      const total = rows.filter(matches).length;
      moreBtn.hidden = total <= shown;
      empty.hidden = total > 0;
    };

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        activeTag = pill.dataset.tag ?? 'all';
        shown = PAGE;
        pills.forEach((p) => p.setAttribute('aria-pressed', String(p === pill)));
        render();
      });
    });

    moreBtn.addEventListener('click', () => {
      shown += PAGE;
      render();
    });

    render();
  }
</script>
