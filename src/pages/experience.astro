---

<Base
  title="Experience — Twenty-five years in the second seat | Tom Vranas"
  description="Track record: seats held across operations, people, marketing, and innovation — and a featured case study of three add-on integrations through the Zentro platform."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Track Record</p>
      <h1 style="margin-top: 0.9rem;">Twenty-five years in the second seat.</h1>

      <div class="tabs" role="tablist" aria-label="Work views" style="margin-top: 2rem;">
        <button
          class="tab"
          id="tab-track-record"
          role="tab"
          aria-selected="true"
          aria-controls="panel-track-record"
          data-view="track-record"
        >
          Track Record
        </button>
        <button
          class="tab"
          id="tab-case-studies"
          role="tab"
          aria-selected="false"
          tabindex="-1"
          aria-controls="panel-case-studies"
          data-view="case-studies"
        >
          Case Studies
        </button>
      </div>

      <div
        class="tab-panel"
        id="panel-track-record"
        role="tabpanel"
        aria-labelledby="tab-track-record"
      >
        <div class="dossiers" style="margin-top: 2rem;">
          {roles.map((r, i) => <Dossier {...r} index={String(i + 1).padStart(2, '0')} />)}
        </div>

        <p style="margin-top: 1.75rem;">
          The pattern across all of them: companies in transition, a strong-vision leader in the
          first seat, and a machine that needed building or fixing &mdash; usually a problem I
          hadn&rsquo;t seen before, solved anyway. Industry changes; the job doesn&rsquo;t.
        </p>
      </div>

      <div
        class="tab-panel"
        id="panel-case-studies"
        role="tabpanel"
        aria-labelledby="tab-case-studies"
        hidden
      >
        <div class="case-list" style="margin-top: 2rem;">
          {
            caseStudies.map((cs) => (
              <a class="case-card" href={`/experience/case-study/${cs.slug}`}>
                <h2 class="case-card__title">{cs.title}</h2>
                <p class="case-card__result">{cs.result}</p>
                <span class="case-card__more" aria-hidden="true">
                  Read &rarr;
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  // Segmented control for /work: client-side show/hide (no reload), linkable
  // via ?view=case-studies, ARIA tabs with arrow-key support. No animation.
  const tablist = document.querySelector<HTMLElement>('.tabs[role="tablist"]');
  if (tablist) {
    const tabs = Array.from(tablist.querySelectorAll<HTMLButtonElement>('[role="tab"]'));

    const activate = (view: string, push: boolean) => {
      tabs.forEach((tab) => {
        const selected = tab.dataset.view === view;
        tab.setAttribute('aria-selected', String(selected));
        tab.tabIndex = selected ? 0 : -1;
        const panel = document.getElementById(tab.getAttribute('aria-controls')!);
        if (panel) panel.hidden = !selected;
      });
      if (push) {
        const url = new URL(window.location.href);
        if (view === 'case-studies') url.searchParams.set('view', 'case-studies');
        else url.searchParams.delete('view');
        history.replaceState({}, '', url);
      }
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activate(tab.dataset.view!, true));
      tab.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        e.preventDefault();
        const i = tabs.indexOf(tab);
        const next = e.key === 'ArrowRight' ? (i + 1) % tabs.length : (i - 1 + tabs.length) % tabs.length;
        tabs[next].focus();
        activate(tabs[next].dataset.view!, true);
      });
    });

    const initial = new URLSearchParams(window.location.search).get('view');
    if (initial === 'case-studies') activate('case-studies', false);
  }
</script>
