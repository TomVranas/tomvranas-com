---
import Base from '../layouts/Base.astro';
import Ph from '../components/Ph.astro';
import Figure from '../components/Figure.astro';
import Dossier from '../components/Dossier.astro';
import StatBand from '../components/StatBand.astro';
import teamPhoto from '../assets/photos/placeholder-team.svg';
import actionPhoto from '../assets/photos/placeholder-action.svg';

// Role dossiers, reverse chronological. Copy verbatim from the rebuild spec.
