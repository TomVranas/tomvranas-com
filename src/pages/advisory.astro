import Base from '../layouts/Base.astro';
---

<Base
  title="Advisory — One skill set, four formats | Tom Vranas"
  description="Fractional COO and Chief of Staff, operating system installation, transition and integration sprints, and executive coaching — monthly retainers or defined sprints."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Ways to Work Together</p>
      <h1 style="margin-top: 0.9rem;">One skill set, four formats.</h1>

      <p style="margin-top: 1.5rem;">
        Every engagement is the same underlying motion &mdash; diagnose, fix, grow, systematize
        &mdash; at different depths. Pick the depth that matches your situation. All of them end
        the same way: with your team running it, not me.
      </p>

      <h2 style="margin-top: 3rem;">Engagements</h2>

      <div class="proof-blocks" style="margin-top: 1.25rem;">
        <div class="proof-block">
          <h3>Fractional COO / Chief of Staff.</h3>
          <p>
            The full second seat, part-time. I sit beside the CEO, own the operating cadence, and
            run the machine while you run the vision &mdash; installing the operating system,
            finishing the stalled integration, fixing the broken function as part of the seat, not
            as separate line items. For companies between &ldquo;founder does everything&rdquo; and
            &ldquo;ready for a full-time COO.&rdquo;
          </p>
        </div>
        <div class="proof-block">
          <h3>Coaching &amp; Advisory.</h3>
          <p>
            One-on-one work with founders and operating leaders &mdash; usually someone stepping
            into a bigger seat than they&rsquo;ve held before. Direct, practical, built on having
            actually sat in the seats. No personality assessments, no inspiration &mdash; we look
            at your actual business and fix actual things.
          </p>
        </div>
        <div class="proof-block">
          <h3>Board &amp; Advisory Seats.</h3>
          <p>
            A formal seat for sponsors and boards that want an operator&rsquo;s eye on the
            portfolio company between meetings &mdash; someone who reads the operating reality
            behind the deck and tells you what the quarterly update won&rsquo;t.
          </p>
        </div>
      </div>

      <blockquote class="pull-quote" style="margin-top: 3rem;">
        &ldquo;Predictable systems and high-performing teams are the only durable competitive
        advantage. Everything else gets copied.&rdquo;
      </blockquote>

      <p style="margin-top: 2.5rem;">
        <a class="btn" href="/contact">Inquire about working together</a>
      </p>
    </div>
  </section>
</Base>
