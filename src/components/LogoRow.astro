---
// Logo row. Tom supplies ~8 clean grayscale logo files into
// src/assets/logos/ — the old site's logo images are NOT scraped (many are
// screenshots). Real logos render grayscale at rest, full color on hover
// (desktop); grayscale always on touch. Until files exist, named placeholder
// boxes render in the agreed order so the row can't ship unnoticed.
import type { ImageMetadata } from 'astro';

const logos = Object.entries(
  import.meta.glob<{ default: ImageMetadata }>('../assets/logos/*.{png,svg,jpg,jpeg,webp}', {
    eager: true,
  })
).sort(([a], [b]) => a.localeCompare(b));

const placeholderSlots = [
  'Apple',
  'NBC',
  'The Princeton Review',
  'CareerBuilder',
  'US Cellular',
  'Northwestern University',
  'Zentro',
  'Everywhere Wireless',
];
---

{
  logos.length > 0 ? (
    <div class="logo-row">
      {logos.map(([path, mod]) => (
        <img
          src={mod.default.src}
          alt={path
            .split('/')
            .pop()!
            .replace(/\.[^.]+$/, '')
            .replace(/[-_]/g, ' ')}
          loading="lazy"
        />
      ))}
    </div>
  ) : (
    <div class="logo-row logo-row--placeholder" aria-label="Logo placeholders pending final files">
      {placeholderSlots.map((name) => (
        <span class="logo-chip">{name}</span>
      ))}
    </div>
  )
}
