---
// One expandable role dossier (Work page). Native <details>/<summary> — no
// JS, keyboard-accessible. Every role uses the identical Context / Mandate /
// Owned / Outcomes template. Outcomes may be plain strings or
// { text?, pending? } objects; `pending` renders as a yellow placeholder so
// unverified figures can't ship unnoticed.
interface Outcome {
  text?: string;
  pending?: string;
}

interface Props {
  index: string;
  years: string;
  company: string;
  role: string;
  mandate: string;
  context: string;
  fullMandate: string;
  owned: string;
  outcomes: (string | Outcome)[];
  footerText?: string;
  footerHref?: string;
  // One or more case-study links shown at the foot of the panel. Takes
  // precedence over footerText/footerHref when provided.
  links?: { text: string; href: string }[];
}

const {
  index,
  years,
  company,
  role,
  mandate,
  context,
  fullMandate,
  owned,
  outcomes,
  footerText,
  footerHref,
  links,
} = Astro.props;

const footerLinks = links ?? (footerText && footerHref ? [{ text: footerText, href: footerHref }] : []);

const normalized = outcomes.map((o) => (typeof o === 'string' ? { text: o } : o));
---

<details class="dossier">
  <summary class="dossier__summary">
    <span class="dossier__index" aria-hidden="true">{index}</span>
    <span class="dossier__content">
      <span class="dossier__years">{years}</span>
      <span class="dossier__head">
        <span class="dossier__company">{company}</span>
        <span class="dossier__role">{role}</span>
      </span>
      <span class="dossier__mandate">{mandate}</span>
    </span>
    <span class="dossier__indicator" aria-hidden="true"></span>
  </summary>
  <div class="dossier__body">
    <dl class="dossier__dl">
      <dt>Context</dt>
      <dd>{context}</dd>
      <dt>Mandate</dt>
      <dd>{fullMandate}</dd>
      <dt>Owned</dt>
      <dd>{owned}</dd>
      <dt>Outcomes</dt>
      <dd>
        <ul class="dossier__outcomes">
          {
            normalized.map((o) => (
              <li>
                {o.text}
                {o.text && o.pending && ' '}
                {o.pending && <mark class="ph">{o.pending}</mark>}
              </li>
            ))
          }
        </ul>
      </dd>
    </dl>
    {
      footerLinks.length > 0 && (
        <p class="dossier__footer">
          {footerLinks.map((l, i) => (
            <>
              {i > 0 && <span class="dossier__footer-sep" aria-hidden="true"> · </span>}
              <a href={l.href}>{l.text}</a>
            </>
          ))}
        </p>
      )
    }
  </div>
</details>
