---
// Fund-factsheet stat band: oversized IBM Plex Mono numerals over small-caps
// labels, each on a ledger rule. Pass `pending` on a stat to flag an
// unverified figure (renders the value as a yellow placeholder).
// Usage: <StatBand stats={[{ value: '25', label: 'Years operating' }]} />
interface Stat {
  value: string;
  label: string;
  pending?: boolean;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<dl class="stat-band" style={`--stat-count: ${stats.length}`}>
  {
    stats.map((s) => (
      <div class="stat">
        <dt class="stat__value">
          {s.pending ? <mark class="ph">{s.value}</mark> : s.value}
        </dt>
        <dd class="stat__label">{s.label}</dd>
      </div>
    ))
  }
</dl>
