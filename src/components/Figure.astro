---
// Photos render as deal-book exhibits: hairline border, grayscale,
// IBM Plex Mono caption — evidence, not decoration.
// `pending` marks the caption yellow (same rule as <Ph>: placeholders
// must not ship unnoticed) and skips the grayscale filter so the
// placeholder art's yellow chip stays visible.
// Usage: <Figure src={photo} alt="…" caption="ALL-HANDS, ZENTRO, 2019" />
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption: string;
  pending?: boolean;
  /** Above-the-fold figures (home headshot) should not lazy-load. */
  eager?: boolean;
}

const { src, alt, caption, pending = false, eager = false } = Astro.props;
const raster =
  src.format !== 'svg'
    ? { widths: [480, 720, 1440], sizes: '(max-width: 760px) 100vw, 720px' }
    : {};
---

<figure class:list={['figure', { 'figure--pending': pending }]}>
  <Image src={src} alt={alt} loading={eager ? 'eager' : 'lazy'} {...raster} />
  <figcaption>{pending ? <mark class="ph">{caption}</mark> : caption}</figcaption>
</figure>
