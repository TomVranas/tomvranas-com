---
import { SITE } from '../config';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const nav = [
  { label: 'Home', href: '/' },
  { label: 'Experience', href: '/experience' },
  { label: 'Engagements', href: '/engagements' },
  { label: 'Contact', href: '/contact' },
];
const isCurrent = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="site-header">
  <div class="container-wide site-header__inner">
    <a class="site-header__brand" href="/" aria-label="Tom Vranas — home">
      <span class="site-header__name">Tom Vranas</span>
      <span class="site-header__monogram" aria-hidden="true">TV</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      {
        nav.map((item) => (
          <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="site-header__ext">
      <a href={SITE.linkedin} target="_blank" rel="me noopener">LinkedIn</a>
      <a href={SITE.medium} target="_blank" rel="me noopener">Medium</a>
    </div>
  </div>
</header>

<script>
  // Sticky header condenses after a small scroll: full wordmark + ext links
  // at the top, "TV" monogram + nav only once scrolling. Class toggle only —
  // the smooth height/border transition is CSS (and is suppressed for
  // prefers-reduced-motion via the global reset).
  const header = document.querySelector('.site-header');
  if (header) {
    const update = () => header.classList.toggle('is-condensed', window.scrollY > 64);
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
