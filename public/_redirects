# Cloudflare Pages redirects — preserves Squarespace SEO across DNS cutover.
# NOTE: Cloudflare Pages honors only the first ~100 rules, so per-post 301s
# are handled by functions/_middleware.js. This file is the wildcard baseline.

/work              /experience         301
/advisory          /engagements        301
/coachingpress     /engagements        301
/toms-world/*      /contact            301
/home              /                   301
/home-old          /                   301
/sitemap.xml       /sitemap-index.xml  301

/blog-vranas/tag/*       /writing       301
/blog-vranas/category/*  /writing       301
# slugs preserved in migration -> 1:1 map (one case-fixed slug first)
/blog-vranas/fave-excel-kiwi-kk8r5-1jtaQ  /writing/fave-excel-kiwi-kk8r5-1jtaq  301
/blog-vranas/*     /writing/:splat     301
/blog/*            /writing/:splat     301
/blog              /writing            301
/blog-vranas       /writing            301

